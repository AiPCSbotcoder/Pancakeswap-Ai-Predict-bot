# ─── BSC RPC Configuration ───
BSC_RPC_URL=https://bsc-dataseed1.binance.org/
BSC_WS_URL=wss://bsc-ws-node.nariox.org:443
BSC_QUICKNODE_URL=
BSC_ANKR_URL=https://rpc.ankr.com/bsc

# ─── PancakeSwap ───
PANCAKE_ROUTER_V2=0x10ED43C718714eb63d5aA57B78B54704E256024E
PANCAKE_FACTORY_V2=0xcA143Ce32Fe78f1f7019d7d551a6402fC5350c73

# ─── BSCScan API ───
BSCSCAN_API_KEY=your_bscscan_api_key

# ─── Model Registry ───
MODEL_REGISTRY_URL=https://your-cdn.com/models
MODEL_VERSION=latest

# ─── Telegram ───
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
TELEGRAM_ALERT_LEVEL=SIGNAL

# ─── Web Dashboard ───
WEB_HOST=0.0.0.0
WEB_PORT=8080

# ─── Alert Configuration ───
ALERT_MIN_CONFIDENCE=65
ALERT_RATE_LIMIT=30

# ─── Logging ───
LOG_LEVEL=INFO
LOG_FORMAT=json
